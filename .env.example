# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development                              # development | production
APP_SECRET_KEY=change-this-secret                # admin key interno (scripts/cron)
APP_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000            # CORS — lista separada por coma

# ─── LLM (OpenAI) ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o                              # Modelo para agentes (gpt-4o-mini para router)

# ─── Redis (cache + sesiones + pubsub) ───────────────────────────────────────
# REDIS_PASSWORD lo consume docker-compose para arrancar redis con --requirepass.
# REDIS_URL lo consume la API (formato: redis://:PASSWORD@host:port/db).
REDIS_PASSWORD=change-me-to-a-strong-secret
REDIS_URL=redis://:change-me-to-a-strong-secret@redis:6379/0

# ─── Postgres (Supabase, dual-write + source of truth) ───────────────────────
# URI del transaction pooler (Connect → Transaction pooler en Supabase).
# Vacío desactiva dual-write (solo Redis — NO recomendado en prod).
DATABASE_URL=

# ─── Supabase Auth (login de la consola) ─────────────────────────────────────
SUPABASE_URL=https://<PROJECT_ID>.supabase.co
SUPABASE_SECRET_KEY=eyJ...                       # service_role key (NO la anon)

# ─── Pinecone (RAG cursos) ───────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=cursos-medicos

# ─── WhatsApp Meta Cloud API (canal principal) ───────────────────────────────
WHATSAPP_TOKEN=                                  # Token permanente de acceso
WHATSAPP_PHONE_NUMBER_ID=                        # ID del número en Meta
WHATSAPP_WABA_ID=                                # WABA ID (para plantillas HSM)
WHATSAPP_VERIFY_TOKEN=                           # Token del webhook GET (verificación)
WHATSAPP_APP_SECRET=                             # App Secret para validar firmas
WHATSAPP_APP_ID=                                 # App ID (Resumable Upload API)

# ─── Botmaker (canal alternativo) ────────────────────────────────────────────
# OAuth2 (recomendado):
BOTMAKER_CLIENT_ID=
BOTMAKER_SECRET_ID=
BOTMAKER_REFRESH_TOKEN=
# O access-token estático (dev/testing):
BOTMAKER_API_KEY=
BOTMAKER_BASE_URL=https://go.botmaker.com/api/v1.0
BOTMAKER_WEBHOOK_SECRET=

# ─── Twilio (WhatsApp sandbox) ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886       # Sandbox number

# ─── Zoho CRM ────────────────────────────────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_REDIRECT_URI=https://your-domain.com/auth/zoho/callback
ZOHO_BASE_URL=https://www.zohoapis.com/crm/v6
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com

# ─── Pagos ───────────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-...
MP_PUBLIC_KEY=APP_USR-...
MP_WEBHOOK_SECRET=

REBILL_API_KEY=
REBILL_BASE_URL=https://api.rebill.to/v2

# ─── Cloudflare R2 (media del inbox, S3-compatible) ──────────────────────────
# Vacío desactiva uploads (fallback a filesystem local).
R2_ENDPOINT=                                     # https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=                                       # ej: msk-multiagente-media
R2_PUBLIC_URL=                                   # ej: https://pub-XXXX.r2.dev

# ─── Business hours (widget + WhatsApp fuera de horario) ─────────────────────
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=18
BUSINESS_TIMEZONE=America/Argentina/Buenos_Aires
BUSINESS_DAYS=0,1,2,3,4                          # 0=Lunes, 6=Domingo
OFF_HOURS_MESSAGE=Gracias por escribirnos. Nuestro horario de atención es de Lunes a Viernes de 9:00 a 18:00 hs (Argentina). Te responderemos a la brevedad.

# ─── Observabilidad ──────────────────────────────────────────────────────────
SENTRY_DSN=                                      # Vacío desactiva Sentry
SENTRY_TRACES_SAMPLE_RATE=0.1                    # 10% de requests traceados

# ─── Notificaciones (handoff a humano) ───────────────────────────────────────
SLACK_WEBHOOK_URL=
